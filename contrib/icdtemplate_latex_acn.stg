group icd_acn;

//delimiters "$", "$"

NewLine() ::= "\n"
OddRow() ::= ""
EvenRow() ::= ""

Integer()       ::= "INTEGER"
BitString()     ::= "BIT-STRING"
OctetString()   ::= "OCTET-STRING"
Boolean()       ::= "BOOLEAN"
Choice()        ::= "CHOICE"
Enumerated()    ::= "ENUMERATED"
IA5String()     ::= "IA5String"
NumericString() ::= "NumericString"
NullType() ::= "NULL"
NullTypeWithBitPattern(sPattern) ::= "fixed pattern: '$sPattern$'B"
NullTypeWithBytePattern(arruOctets) ::= "fixed pattern:  '$arruOctets:{b|$b;format=\"X2\"$}$'H"

Real()          ::= "REAL"
Sequence()      ::= "SEQUENCE"
SequenceOf()    ::= "SEQUENCE-OF"
ObjectIdentifier()       ::= "OBJECT IDENTIFIER"
RelativeOid()       ::= "RELATIVE-OID"

EmitRowWith3Dots() ::= <<
\multicolumn{9}{|c|}{. . .} \\\\ \hline
>>

EmitFilePart2(sFileName, arrsAsn1Content) ::= <<
\section{File: \protect\detokenize{$sFileName$}}
\begin{lstlisting}[style=asn1style]
$arrsAsn1Content$
\end{lstlisting}
>>

EmitModule(sModName, sAsn1FileName, soAcnFileName, arrsComments, arrsTases) ::= <<
\clearpage
\section{Module \protect\detokenize{$sModName$}}\label{secICD$sModName$}
\textit{Defined in: \protect\detokenize{$sAsn1FileName$}$if(soAcnFileName)$, \protect\detokenize{$soAcnFileName$}$endif$.}

$arrsComments;separator="\n\n"$

$arrsTases;separator="\n"$
>>

EmitNavLink(sTitle, sTarget) ::= <<
\protect\detokenize{$sTitle$}~\ref{secICD$sTarget$}
>>

EmitTass(sTypeContent) ::= <<
\begin{lstlisting}[style=asn1style]
$sTypeContent$
\end{lstlisting}
\bigskip
>>

ItemNumber(nIndex) ::= <<
Item $nIndex$
>>

LeftDiple() ::= "(@*\textless{}*@)"
RightDiple() ::= "(@*\textgreater{}*@)"

AcnKeyword(sKeyword) ::= "(@*\textbf{$sKeyword$}*@)"
StringLiteral(sStringLiteral) ::= "(@*\texttt{\protect\detokenize{$sStringLiteral$}}*@)"
TasName(sTasName, sTasNameC) ::= "(@*\label{appACN$sTasNameC$}\textbf{\protect\detokenize{$sTasName$}}*@)"
TasName2(sTasName, sTasNameC) ::= "(@*\hyperref[appASN$sTasNameC$]{\protect\detokenize{$sTasName$}}*@)"
BlueTas(sBlueTasC,sTasName) ::= "(@*\label{appASN$sBlueTasC$}\protect\detokenize{$sTasName$}*@)"
Asn1Token(sKeyword) ::= "(@*\textbf{$sKeyword$}*@)"
Comment(sComment) ::= "(@*\textit{\protect\detokenize{$sComment$}}*@)"

EmitEnumItem(sName, nValue) ::= <<
\item \protect\detokenize{$sName$} ($nValue$)
>>

EmitEnumItemWithComment(sName, nValue, sComment) ::= <<
\item \protect\detokenize{$sName$} ($nValue$) -- \protect\detokenize{$sComment$}
>>

EmitEnumInternalContents(arrsItems) ::= <<
Possible values:
\begin{itemize}
$arrsItems;separator="\n"$
\end{itemize}
>>

EmitSequenceOrChoice(bIsAnonymousType, sTasName, sTasNameC, bHasAcnDef, sAsn1Kinf, sMinBytes, sMaxBytes, sMaxBitsExplained, sCommentLine, arrsChildren, arrsParams, arrsComments) ::= <<
\subsection{\protect\detokenize{$sTasName$}}\label{secICD$sTasNameC$}

\begin{itemize}
\item ASN.1 Type: \protect\detokenize{$sTasName$} ($if(bIsAnonymousType)$anonymous $endif$$sAsn1Kinf$)
\item Source: \hyperref[appASN$sTasNameC$]{ASN.1}$if(bHasAcnDef)$ | \hyperref[appACN$sTasNameC$]{ACN}$endif$
\item Min size: $sMinBytes$ bytes
\item Max size: $sMaxBytes$ bytes $sMaxBitsExplained$
\end{itemize}

$if(sCommentLine)$\protect\detokenize{$sCommentLine$}$endif$

$if(arrsParams)$
\subsubsection*{ACN Parameters}
\begin{longtable}{|c|c|c|}
\hline
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endhead
$arrsParams$
\end{longtable}
$endif$

\begin{longtable}{|c|p{3cm}|p{5cm}|c|p{3cm}|c|c|c|c|}
\caption{Type content for \protect\detokenize{$sTasName$}}\label{tabparam$sTasNameC$} \\\\
\hline
\rowcolor{gray!50}
\textbf{No} & \textbf{Field} & \textbf{Comment} & \textbf{Present} & \textbf{Type} & \textbf{Constraint} & \textbf{Min} & \textbf{Max} & \textbf{Unit} \\\\
\rowcolor{gray!50}
 & & & & & & \textbf{Bits} & \textbf{Bits} & \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{No} & \textbf{Field} & \textbf{Comment} & \textbf{Present} & \textbf{Type} & \textbf{Constraint} & \textbf{Min} & \textbf{Max} & \textbf{Unit} \\\\
\rowcolor{gray!50}
 & & & & & & \textbf{Bits} & \textbf{Bits} & \\\\
\hline\\hline
\endhead
$arrsChildren;separator="\n\\hline\n"$
\hline
\end{longtable}
>>

EmitSeqOrChoiceRow(sCssClass, nIndex, sName, sComment, sPresentWhen, sType, sConstraint, sMin, sMax, noAlignToNextSize, soUnit) ::= <<
$if(noAlignToNextSize)$
 & padding field & present due to align-to-next property & & padding bits & & 0 & $noAlignToNextSize$ & \protect\detokenize{$soUnit$} \\\\ \hline
$endif$
$nIndex$ & \protect\detokenize{$sName$} & \protect\detokenize{$sComment$} & \protect\detokenize{$sPresentWhen$} & $sType$ & \protect\detokenize{$sConstraint$} & $sMin$ & $sMax$ & \protect\detokenize{$soUnit$} \\\\
>>

EmitSequencePreambleSingleComment(nIndex, sOptChildName) ::= <<
\item bit $nIndex$ == 1 \$\Rightarrow\$ \protect\detokenize{$sOptChildName$} is present
>>

EmitSequencePreambleComment(arrsOptWihtNoPresentWhenChildren) ::= <<
Special field used by ACN to indicate the presence/absence of optional fields that do not have the present when property.
\begin{itemize}
$arrsOptWihtNoPresentWhenChildren;separator="\n"$
\end{itemize}
>>

EmitChoiceIndexComment() ::= <<
Special field used by ACN to indicate which choice alternative is present.
>>

EmitChoiceChild(sCssClass, nIndex, sName, sComment,  sType, sConstraint, sMin, sMax) ::= <<
$nIndex$ & \protect\detokenize{$sName$} & \protect\detokenize{$sComment$} & always & $sType$ & \protect\detokenize{$sConstraint$} & $sMin$ & $sMax$ & \\\\
>>

EmitSeqChild_RefType(sRefName, sRefNameC) ::= <<
\protect\detokenize{$sRefName$}~\ref{secICD$sRefNameC$}
>>

EmitPrimitiveType(bIsAnonymousType, sTasName, sTasNameC, bHasAcnDef, sAsnKindName, sMinBytes, sMaxBytes, sMaxBitsExplained, sCommentLine, sAsn1Constraints, sMinBits, sMaxBits, arrsParams, arrsComments, soUnit) ::= <<
\subsection{\protect\detokenize{$sTasName$}}\label{secICD$sTasNameC$}

\begin{itemize}
\item ASN.1 Type: \protect\detokenize{$sTasName$} ($if(bIsAnonymousType)$anonymous $endif$$sAsnKindName$)
\item Source: \hyperref[appASN$sTasNameC$]{ASN.1}$if(bHasAcnDef)$ | \hyperref[appACN$sTasNameC$]{ACN}$endif$
\item Min size: $sMinBytes$ bytes
\item Max size: $sMaxBytes$ bytes $sMaxBitsExplained$
\end{itemize}

$if(sCommentLine)$\protect\detokenize{$sCommentLine$}$endif$

$if(arrsParams)$
\subsubsection*{ACN Parameters}
\begin{longtable}{|c|c|c|}
\hline
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endhead
$arrsParams$
\end{longtable}
$endif$

\begin{longtable}{|c|c|c|c|}
\caption{Type content for \protect\detokenize{$sTasName$}}\label{tabparam$sTasNameC$} \\\\
\hline
\rowcolor{gray!50}
\textbf{Constraints} & \textbf{Min Bits} & \textbf{Max Bits} & \textbf{Unit} \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{Constraints} & \textbf{Min Bits} & \textbf{Max Bits} & \textbf{Unit} \\\\
\hline\\hline
\endhead
\protect\detokenize{$sAsn1Constraints$} & $sMinBits$ & $sMaxBits$$sMaxBitsExplained$ & \protect\detokenize{$soUnit$} \\\\
\hline
\end{longtable}
>>

EmitSizeable(bIsAnonymousType, sTasName, sTasNameC, bHasAcnDef, sKind, sMinBytes, sMaxBytes, sMaxBitsExplained, sCommentLine, arrsRows, arrsParams, arrsComments) ::= <<
\subsection{\protect\detokenize{$sTasName$}}\label{secICD$sTasNameC$}

\begin{itemize}
\item ASN.1 Type: \protect\detokenize{$sTasName$} ($if(bIsAnonymousType)$anonymous $endif$$sKind$)
\item Source: \hyperref[appASN$sTasNameC$]{ASN.1}$if(bHasAcnDef)$ | \hyperref[appACN$sTasNameC$]{ACN}$endif$
\item Min size: $sMinBytes$ bytes
\item Max size: $sMaxBytes$ bytes $sMaxBitsExplained$
\end{itemize}

$if(sCommentLine)$\protect\detokenize{$sCommentLine$}$endif$

$if(arrsParams)$
\subsubsection*{ACN Parameters}
\begin{longtable}{|c|c|c|}
\hline
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{No} & \textbf{ACN Parameters} & \textbf{Type} \\\\
\hline\\hline
\endhead
$arrsParams$
\end{longtable}
$endif$

\begin{longtable}{|c|p{3cm}|p{5cm}|c|p{3cm}|c|c|c|}
\caption{Type content for \protect\detokenize{$sTasName$}}\label{tabparam$sTasNameC$} \\\\
\hline
\rowcolor{gray!50}
\textbf{No} & \textbf{Field} & \textbf{Comment} & \textbf{Present} & \textbf{Type} & \textbf{Constraint} & \textbf{Min Bits} & \textbf{Max Bits} \\\\
\hline\\hline
\endfirsthead
\rowcolor{gray!50}
\textbf{No} & \textbf{Field} & \textbf{Comment} & \textbf{Present} & \textbf{Type} & \textbf{Constraint} & \textbf{Min Bits} & \textbf{Max Bits} \\\\
\hline\\hline
\endhead
$arrsRows;separator="\n\\hline\n"$
\hline
\end{longtable}
>>

PrintParam(nIndex, sName, sType, nColSpan) ::= <<
$nIndex$ & \protect\detokenize{$sName$} & $sType$ \\\\
>>

RootCss() ::= ""

RootHtml(arrsFiles1, arrsFiles2, bAcnParamsMustBeExplained, arrsFiles3, sCssFileName, navLinks) ::= <<
\documentclass[10pt,a4paper]{article}
\usepackage[T1]{fontenc}
\usepackage[utf8]{inputenc}
\usepackage{lmodern}
\usepackage{longtable}
\usepackage{pdflscape}
\usepackage{multirow}
\usepackage[table]{xcolor}
\usepackage{hyperref}
\usepackage{tocloft}
\usepackage{listings}

% Compact Table of Contents
\setlength{\cftbeforesecskip}{2pt}
\setlength{\cftbeforesubsecskip}{0pt}

\lstdefinestyle{asn1style}{
  basicstyle=\ttfamily\small,
  breaklines=true,
  tabsize=4,
  showstringspaces=false,
  escapeinside={(@*}{*@)},
  columns=fullflexible,
  keepspaces=true
}

\title{ICD}
\begin{document}
\maketitle

\tableofcontents
\newpage

\begin{landscape}
$arrsFiles1;separator="\n"$

$if(bAcnParamsMustBeExplained)$
\section*{ACN Parameters}
\label{appACNPARAMSEXPLAINED123}
In the standard ASN.1 encodings such as uPER, BER etc, the encoding and decoding of any type has no external dependencies. For example, the encoded data for a SEQUENCE OF depends on the number of items in the SEQUENCE OF (the length determinant) and the type of item contained in the SEQUENCE. On the other hand, ACN allows types to be parameterized. For instance, the length of a SEQUENCE OF may be determined by the value of an external field. In this case, the SEQUENCE OF is parameterized and the input parameter is the field providing the length.
$endif$

$arrsFiles2;separator="\n"$

$arrsFiles3;separator="\n"$
\end{landscape}
\end{document}
>>

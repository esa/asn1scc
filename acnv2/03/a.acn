MyModule DEFINITIONS ::= BEGIN

PDU [] {
   hdr [] {
      version NULL [pattern '01'H],
      buffers-length BUFFER-LENGTH-TYPE [encoding pos-int, size 8]
   },
   payload [] {
	   case1 [] {
		  int-field [encoding twos-complement, size 32],
		  buffer [size  hdr.buffers-length]
	   },
	   case2 [] {
		  int-field [encoding twos-complement, size 32],
		  buffer [size  hdr.buffers-length]
	   }
   }
}



END
